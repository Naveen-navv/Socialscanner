# Anthropic API key (for AI reply generation in browser)
# Get yours at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Apify credentials (for fetching live Reddit threads server-side)
# Get yours at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...
# Optional: actor used for Reddit scraping
APIFY_REDDIT_ACTOR_ID=apify/reddit-scraper

# PostgreSQL connection string (for persistent user data)
DATABASE_URL=postgresql://user:password@host:5432/dbname
