# Anthropic API key (for AI reply generation in browser)
# Get yours at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Reddit API credentials (for fetching live threads server-side)
# Get yours at: https://www.reddit.com/prefs/apps → create "script" type app
REDDIT_CLIENT_ID=xxx
REDDIT_CLIENT_SECRET=xxx

# PostgreSQL connection string (for persistent user data)
DATABASE_URL=postgresql://user:password@host:5432/dbname
